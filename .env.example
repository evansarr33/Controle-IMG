# Copie ce fichier en ".env" et renseigne tes propres valeurs.
# Le fichier ".env" ne doit JAMAIS être commité (voir .gitignore).
# Ces identifiants sont utilisés uniquement par scripts/generate-manifest.js,
# exécuté en local — ils ne sont jamais envoyés au site publié.

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optionnel : ne récupérer qu'un sous-dossier Cloudinary
# CLOUDINARY_FOLDER=a-verifier/
